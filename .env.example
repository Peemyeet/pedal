# คัดลอกเป็น .env
#
# บังคับสำหรับแอป (PostgreSQL) — SQLite แบบไฟล์ไม่เหมาะกับ Vercel/serverless
# ตัวอย่าง: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pedal?schema=public"
#
# สำคัญ: ไฟล์ .env ถูก .gitignore — การใส่ค่าในเครื่องอย่างเดียวไม่ทำให้ Vercel ได้ค่านั้น
# ต้องไป Vercel → Project → Settings → Environment Variables แล้วเพิ่ม DATABASE_URL
# (ค่าเดียวกับใน .env) สำหรับ Production / Preview แล้ว Redeploy
# หรือเชื่อม "Vercel Postgres" / "Neon" ในแดชบอร์ด — แอปจะใช้ POSTGRES_PRISMA_URL / NEON_DATABASE_URL อัตโนมัติ

# NextAuth (ล็อกอินร้าน + งานหลังบ้าน) — สร้างค่า: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
# ตัวอย่าง dev: http://localhost:3000  | production: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# รันครั้งเดียว: npm run db:create-admin — สร้าง/อัปเดตบัญชีแอดมิน
# ล็อกอิน: ชื่อผู้ใช้ pedlai + รหัสตาม ADMIN_PASSWORD (ไม่ต้องมีอีเมล)
# บน production แนะนำเปลี่ยนรหัส / ชื่อผู้ใช้แล้วรันสคริปต์นี้ใหม่
ADMIN_USERNAME="pedlai"
ADMIN_PASSWORD="pedlai.co"
ADMIN_NAME="pedlai"
# ไม่บังคับ — เก็บอีเมลแอดมินได้ถ้าต้องการ
# ADMIN_EMAIL="admin@example.com"
# ไม่บังคับ — สำหรับสคริปต์ npm run import:customers เท่านั้น
# CUSTOMER_XLSX="/absolute/path/to/customers.xlsx"
