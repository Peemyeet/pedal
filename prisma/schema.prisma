generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id              String          @id @default(cuid())
  sku             String?         @unique
  name            String
  description     String?
  productionNotes String?
  price           Float
  stock           Int             @default(0)
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  OrderLine       OrderLine[]
  QuotationLine   QuotationLine[]
}

model Order {
  id                    String      @id @default(cuid())
  number                Int         @unique
  userId                String
  status                OrderStatus @default(PENDING)
  subtotal              Float
  shippingTotal         Float
  grandTotal            Float
  paymentNote           String?
  paymentSlipPath       String?
  paymentSlipUploadedAt DateTime?
  paymentSubmittedAt    DateTime?
  shippingName          String?
  shippingAddress       String?
  shippingPostalCode    String?
  shippingPhone         String?
  trackingNumber        String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  User                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  OrderLine             OrderLine[]

  @@index([status])
  @@index([userId, createdAt])
}

model Customer {
  id               String      @id
  category         String
  customerCode     String
  name             String?
  address          String?
  orderNote        String?
  lastPurchaseNote String?
  billingInfo      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime
  Quotation        Quotation[]

  @@unique([category, customerCode])
}

model OrderLine {
  id           String  @id
  orderId      String
  productId    String
  quantity     Int
  unitPrice    Float
  lineShipping Float   @default(0)
  Order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Product      Product @relation(fields: [productId], references: [id])
}

model Quotation {
  id                       String          @id
  number                   Int             @unique
  customerId               String?
  customerName             String?
  customerContact          String?
  note                     String?
  shippingFee              Float           @default(0)
  status                   QuotationStatus @default(DRAFT)
  paymentConfirmedAt       DateTime?
  paymentTransactionRef    String?
  shippedAt                DateTime?
  trackingNumber           String?
  fulfillmentAddressSource String?
  fulfillmentAddressText   String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime
  Customer                 Customer?       @relation(fields: [customerId], references: [id])
  QuotationLine            QuotationLine[]
}

model QuotationLine {
  id          String    @id
  quotationId String
  productId   String
  quantity    Int
  unitPrice   Float
  shippingFee Float     @default(0)
  Product     Product   @relation(fields: [productId], references: [id])
  Quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id
  username  String   @unique
  email     String?  @unique
  name      String
  password  String
  role      UserRole @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Order     Order[]

  @@index([username])
}

enum OrderStatus {
  PENDING
  CANCELLED
  COMPLETED
}

enum QuotationStatus {
  DRAFT
  QUOTED
  CONFIRMED
  CANCELLED
}

enum UserRole {
  CUSTOMER
  ADMIN
}

model ShopSettings {
  id            String   @id @default("default")
  shortName     String   @default("เผ็ดหลาย")
  nameTh        String   @default("เผ็ดหลาย")
  nameEn        String   @default("PEDLAI")
  address       String   @default("เลขที่ 576 หมู่ที่ 1 ต.วัฒนานคร อ.วัฒนานคร จ.สระแก้ว 27160")
  addressEn     String   @default("576 Moo 1, Wattananakorn, Wattananakorn, Sa Kaeo 27160")
  taxId         String   @default("")
  phonesJson    String   @default("[\"094-428-9199\"]")
  fax           String   @default("")
  email         String   @default("")
  website       String   @default("")
  logoInitials  String   @default("PHL")
  quotationNote String   @default("")
  updatedAt     DateTime @updatedAt
}
