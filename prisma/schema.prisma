generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CANCELLED
  COMPLETED
}

/// ลูกค้าล็อกอินเว็บ (e-commerce) — แยกจาก Customer ในงานหลังบ้าน/Excel
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  name      String
  password  String
  role      UserRole @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@index([username])
}

model Order {
  id             String        @id @default(cuid())
  number         Int           @unique
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         OrderStatus   @default(PENDING)
  subtotal       Float
  shippingTotal  Float
  grandTotal     Float
  /** อ้างอิง/หมายเหตุชำระเงิน (อัปโหลด/พิมพ์ภายหลังได้) */
  paymentNote    String?
  /** หลักฐานการชำระเงินที่ลูกค้าแนบ */
  paymentSlipPath String?
  paymentSlipUploadedAt DateTime?
  /** ลูกค้าแจ้งชำระเงินแล้วเมื่อไหร่ */
  paymentSubmittedAt DateTime?
  /** ที่อยู่จัดส่ง & รหัสไปรษณีย์ (กรอกตอนยืนยันคำสั่ง) */
  shippingName       String?
  shippingAddress    String?
  shippingPostalCode String?
  shippingPhone      String?
  trackingNumber     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime     @updatedAt
  lines          OrderLine[]

  @@index([userId, createdAt])
  @@index([status])
}

model OrderLine {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Float
  lineShipping Float   @default(0)
}

model Product {
  id               String   @id @default(cuid())
  sku              String?  @unique
  name             String
  description      String?
  productionNotes  String?
  price            Float
  stock            Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lines            QuotationLine[]
  orderLines      OrderLine[]
}

/// ลูกค้าจากไฟล์ Excel (ชีต ทั่วไป / เสาวรีย์) และใช้อ้างอิงในใบเสนอราคา
model Customer {
  id                 String   @id @default(cuid())
  category           String
  customerCode       String
  name               String?
  address            String?
  orderNote          String?
  lastPurchaseNote   String?
  billingInfo        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  quotations         Quotation[]

  @@unique([category, customerCode])
}

enum QuotationStatus {
  DRAFT
  QUOTED
  CONFIRMED
  CANCELLED
}

model Quotation {
  id                   String            @id @default(cuid())
  number               Int               @unique
  customerId           String?
  customer             Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName         String?
  customerContact      String?
  note                 String?
  shippingFee          Float             @default(0)
  status                QuotationStatus   @default(DRAFT)
  paymentConfirmedAt    DateTime?
  paymentTransactionRef String?
  shippedAt               DateTime?
  trackingNumber          String?
  fulfillmentAddressSource String?
  fulfillmentAddressText   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime       @updatedAt
  lines                  QuotationLine[]
}

model QuotationLine {
  id           String    @id @default(cuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Float
  shippingFee  Float     @default(0)
}
